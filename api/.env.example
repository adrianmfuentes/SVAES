# ── Database ──────────────────────────────────────────────────────────────────
# Full async URL for psycopg3 driver
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/svaes

# ── Environment ───────────────────────────────────────────────────────────────
# Allowed values: development | production
ENVIRONMENT=development

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Encryption ────────────────────────────────────────────────────────────────
# Required in production. Omit only in dev (ephemeral key generated with a warning).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<generate-and-paste-here>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Required. Comma-separated list of allowed origins.
ALLOWED_ORIGINS=["https://app.example.com","https://www.example.com"]

# ── Celery ──────────────────────────────────────────────────────────────────────
# Broker and result backend for async task processing
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
