#!/usr/bin/env bash
COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# 1. Cargar variables de entorno desde el archivo .env local si existe
if [ -f .env ]; then
    source .env
fi

# 2. Si ya se proporcionó un mensaje (ej. git commit -m "mensaje"), salimos
[ -n "$COMMIT_SOURCE" ] && exit 0

# 3. Obtenemos los cambios cacheados (staged)
DIFF=$(git diff --cached 2>/dev/null)
[ -z "$DIFF" ] && exit 0

# 4. Verificamos que la clave API esté configurada
if [ -z "$GROQ_API_KEY" ]; then
    echo "⚠️ GROQ_API_KEY no está configurada en el .env. Abortando auto-generación."
    exit 0
fi

# 5. Verificamos que 'jq' esté instalado (necesario para escapar comillas en el JSON)
if ! command -v jq &> /dev/null; then
    echo "⚠️ Error: El comando 'jq' no está instalado."
    exit 0
fi

# 6. Definimos el prompt
PROMPT="Eres un experto en control de versiones. Genera un mensaje de commit en español \
siguiendo el estándar Conventional Commits (feat, fix, refactor, docs, chore, test, ci, build, perf, style). \
Reglas estrictas:
- Subject: imperativo, ≤50 caracteres, sin punto final
- Body: solo si el 'por qué' no es obvio, separado por línea en blanco, ≤72 chars por línea
- Sin explicaciones adicionales, sin bloques de markdown, devuelve únicamente el mensaje
- Usa 'feat(scope):' cuando el scope sea relevante

Diff a analizar:
${DIFF}"

# 7. Construimos el payload JSON de forma segura usando jq
JSON_PAYLOAD=$(jq -n --arg content "$PROMPT" '{
  "model": "llama-3.3-70b-versatile",
  "messages": [
    {"role": "system", "content": "Solo devuelve el texto crudo del commit. No uses backticks ni bloques de código markdown."},
    {"role": "user", "content": $content}
  ],
  "temperature": 0.2
}')

echo "🤖 Generando mensaje de commit con Groq..."

# 8. Llamada a la API REST de Groq
RESPONSE=$(curl -s -X POST "https://api.groq.com/openai/v1/chat/completions" \
  -H "Authorization: Bearer $GROQ_API_KEY" \
  -H "Content-Type: application/json" \
  -d "$JSON_PAYLOAD")

# 9. Extraemos el mensaje limpiando las posibles comillas invertidas de markdown (```)
MESSAGE=$(echo "$RESPONSE" | jq -r '.choices[0].message.content // empty' | sed '/^```/d')

# 10. Escribimos en el archivo de commit si la respuesta es válida
if [ -n "$MESSAGE" ] && [ "$MESSAGE" != "null" ]; then
    printf '%s\n' "$MESSAGE" > "$COMMIT_MSG_FILE"
else
    echo "❌ Fallo al generar el mensaje con Groq:"
    echo "$RESPONSE" | jq -r '.error.message // empty'
fi