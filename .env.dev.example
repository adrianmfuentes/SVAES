# Copy this file to .env.dev and fill in your Gmail credentials.
# .env.dev is gitignored — never commit it.
#
# ── Gmail SMTP setup ──────────────────────────────────────────────────────────
# Gmail requires an App Password (not your regular password).
# Steps to get one:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create a new app password → select "Mail" + "Other (custom name)" → "SVAES Dev"
#   5. Copy the 16-character password shown and paste it below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=your.email@gmail.com
