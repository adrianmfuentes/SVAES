[run]
omit =
    api/src/main.py
    api/src/core/config.py
    api/src/__init__.py
    api/src/application/ports/**
    api/src/infrastructure/workers/verification_worker.py
    api/src/infrastructure/primary/routers/api/__init__.py
    api/src/infrastructure/primary/routers/api/v1/__init__.py
    api/src/infrastructure/secondary/database/models/__init__.py
    api/src/infrastructure/secondary/database/repositories/__init__.py
    api/src/infrastructure/secondary/connectors/task_management/__init__.py
    api/src/infrastructure/secondary/connectors/source_control/__init__.py
    api/src/infrastructure/secondary/connectors/documentation/__init__.py
    api/src/infrastructure/secondary/connectors/planning/__init__.py
    api/src/infrastructure/secondary/connectors/change_management/__init__.py
    api/src/infrastructure/secondary/queue/__init__.py
    api/src/infrastructure/secondary/queue/celery_app.py
    api/src/infrastructure/workers/__init__.py
    */alembic/versions/*
    */alembic/env.py
    */migrations/*
    api/src/infrastructure/config/*
    api/src/infrastructure/settings*
    api/src/svaes_api.egg-info/*

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
