# ── Database ──────────────────────────────────────────────────────────────────
# Full async URL for psycopg3 driver
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/svaes

# ── Environment ───────────────────────────────────────────────────────────────
# Allowed values: development | production
ENVIRONMENT=development

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Dev default: http://localhost:4200,http://localhost:3000
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
