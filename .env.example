# Copy this file to .env and fill in values before running docker compose up.

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=svaes
POSTGRES_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Engine ────────────────────────────────────────────────────────────────────
ENGINE_API_KEY=

# ── Admin bootstrap ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ── API (local development without Docker) ────────────────────────────────────
DATABASE_URL=postgresql://svaes:POSTGRES_PASSWORD@localhost:5432/svaes
ENVIRONMENT=development
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
ENGINE_URL=http://localhost:8081
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@svaes.local
APP_BASE_URL=http://localhost:4200
