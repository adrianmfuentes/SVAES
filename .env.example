# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
API_PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=svaes
DB_USER=svaes
DB_PASSWORD=changeme

# Full async URL for the Python API (psycopg3 driver)
DATABASE_URL=postgresql+psycopg://svaes:changeme@localhost:5432/svaes

# ── Auth (Python API) ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Generate ENCRYPTION_KEY with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Auth (legacy) ─────────────────────────────────────────────────────────────
JWT_SECRET=changeme
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Queue ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Connectors ────────────────────────────────────────────────────────────────
JIRA_BASE_URL=
JIRA_API_TOKEN=
GITLAB_BASE_URL=
GITLAB_TOKEN=
CONFLUENCE_BASE_URL=
CONFLUENCE_API_TOKEN=

# ── Notifications ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SLACK_WEBHOOK_URL=
