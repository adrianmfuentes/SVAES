# Copy this file to .env and fill in values before running docker compose up.

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_PEPPER=

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=svaes
POSTGRES_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Engine ────────────────────────────────────────────────────────────────────
ENGINE_API_KEY=

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# REQUIRED: change both values before first boot — they are seeded into the DB
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ── API (local development without Docker) ────────────────────────────────────
DATABASE_URL=postgresql://svaes:POSTGRES_PASSWORD@localhost:5432/svaes
ENVIRONMENT=development
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0
ENGINE_URL=http://localhost:8081
# REQUIRED in production: set to a real SMTP relay, NOT mailhog/localhost
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
APP_BASE_URL=https://yourdomain.com

# ── TLS (production) ──────────────────────────────────────────────────────────
# Path to directory containing fullchain.pem and privkey.pem
# e.g. /etc/letsencrypt/live/yourdomain.com
TLS_CERT_PATH=./certs
